// Exponential Backoff helper
const fetchWithRetry = async (url, options, retries = 5, backoff = 1000) => {
  try {
    const response = await fetch(url, options);
    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
    return await response.json();
  } catch (error) {
    if (retries > 0) {
      await new Promise(resolve => setTimeout(resolve, backoff));
      return fetchWithRetry(url, options, retries - 1, backoff * 2);
    }
    throw error;
  }
};

// PCM to WAV Conversion Utility for TTS
const pcmToWav = (pcmData, sampleRate) => {
  const buffer = new ArrayBuffer(44 + pcmData.length * 2);
  const view = new DataView(buffer);
  const writeString = (offset, string) => {
    for (let i = 0; i < string.length; i++) {
      view.setUint8(offset + i, string.charCodeAt(i));
    }
  };
  writeString(0, 'RIFF');
  view.setUint32(4, 32 + pcmData.length * 2, true);
  writeString(8, 'WAVE');
  writeString(12, 'fmt ');
  view.setUint32(16, 16, true);
  view.setUint16(20, 1, true);
  view.setUint16(22, 1, true);
  view.setUint32(24, sampleRate, true);
  view.setUint32(28, sampleRate * 2, true);
  view.setUint16(32, 2, true);
  view.setUint16(34, 16, true);
  writeString(36, 'data');
  view.setUint32(40, pcmData.length * 2, true);
  for (let i = 0; i < pcmData.length; i++) {
    view.setInt16(44 + i * 2, pcmData[i], true);
  }
  return new Blob([buffer], { type: 'audio/wav' });
};

// --- Data ---
const ON_THIS_DAY = {
  date: "May 4th",
  year: "2019",
  event: "Started the first draft of 'The Summer of Cicadas' while sitting under an old oak tree.",
  mood: "Hopeful"
};

const JOURNEY_PHASES = [
  { year: "1998", title: "The Beginning", desc: "Born in a quiet town where the wind always smelled like rain.", category: "Early Life" },
  { year: "2010", title: "The Curious Student", desc: "Found my first journal. I realized that words could build worlds.", category: "School" },
  { year: "2018", title: "Crossing the Valley", desc: "A difficult period that taught me the strength of silence and resilience.", category: "Struggles" },
  { year: "2024", title: "The Present Garden", desc: "Cultivating stories and helping others find their own voice.", category: "Current" }
];

const FLOWER_TYPES = {
  "Philosophy": { color: "#FF9AA2", type: "tulip" },
  "Memories": { color: "#C7CEEA", type: "daisy" },
  "Life Advice": { color: "#FFDAC1", type: "sunflower" },
  "Unknown": { color: "#E2F0CB", type: "lavender" }
};

const App = () => {
  const [view, setView] = useState('home');
  const [isNight, setIsNight] = useState(false);
  const [isMuted, setIsMuted] = useState(true);
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  
  // AI States
  const [aiLoading, setAiLoading] = useState(false);
  const [activePrompt, setActivePrompt] = useState("Click the button below to generate a ✨ special reflection prompt...");
  const [wisdom, setWisdom] = useState("");
  const [newComment, setNewComment] = useState("");
  const [analyzedMemory, setAnalyzedMemory] = useState("");
  
  const [comments, setComments] = useState([
    { name: "Sophie", text: "This place feels so peaceful. Thank you for sharing, Allen.", likes: 12, category: "Memories" },
    { name: "Haku", text: "The garden visualization is such a beautiful touch.", likes: 8, category: "Philosophy" }
  ]);

  const audioRef = useRef(null);

  // Derive garden from comments
  const gardenPlants = useMemo(() => {
    return comments.map((c, i) => ({
      id: i,
      color: FLOWER_TYPES[c.category || "Unknown"]?.color || "#E2F0CB",
      size: i === 0 ? "scale-125" : "scale-100",
      delay: `${i * 0.2}s`,
      label: c.text.substring(0, 20) + "..."
    })).slice(0, 8);
  }, [comments]);

  // --- Gemini API Calls ---

  const generateAIPrompt = async () => {
    setAiLoading(true);
    const systemPrompt = "You are a thoughtful, introspective writing assistant. Generate a single, profound reflection prompt for a personal journal. The tone should be calm, nostalgic, and Studio Ghibli-inspired. Keep it to one sentence.";
    try {
      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contents: [{ parts: [{ text: "Give me a new prompt." }] }], systemInstruction: { parts: [{ text: systemPrompt }] } })
        }
      );
      const text = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (text) setActivePrompt(text.trim());
    } catch (err) {
      setActivePrompt("The wind is quiet today. Try again in a moment.");
    } finally {
      setAiLoading(false);
    }
  };

  const speakWisdom = async (textToSpeak) => {
    if (!textToSpeak) return;
    setAiLoading(true);
    try {
      const response = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: `Say gently and calmly: ${textToSpeak}` }] }],
            generationConfig: {
              responseModalities: ["AUDIO"],
              speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Kore" } } }
            },
            model: "gemini-2.5-flash-preview-tts"
          })
        }
      );

      const audioPart = response.candidates[0].content.parts[0];
      const pcmBase64 = audioPart.inlineData.data;
      const mimeType = audioPart.inlineData.mimeType;
      const sampleRate = parseInt(mimeType.split('rate=')[1]) || 24000;
      
      const pcmBytes = Uint8Array.from(atob(pcmBase64), c => c.charCodeAt(0));
      const pcm16 = new Int16Array(pcmBytes.buffer);
      const wavBlob = pcmToWav(pcm16, sampleRate);
      const audioUrl = URL.createObjectURL(wavBlob);
      
      if (audioRef.current) {
        audioRef.current.src = audioUrl;
        audioRef.current.play();
      }
    } catch (err) {
      console.error("TTS Error:", err);
    } finally {
      setAiLoading(false);
    }
  };

  const handleImageUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    setAiLoading(true);
    
    const reader = new FileReader();
    reader.onloadend = async () => {
      const base64Data = reader.result.split(',')[1];
      const systemPrompt = "You are a poetic narrator. Look at this image and describe the feeling or memory it evokes in a nostalgic Studio Ghibli style. Keep it to 2-3 sentences. Focus on sensory details like light, air, and emotion.";
      
      try {
        const result = await fetchWithRetry(
          `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{
                role: "user",
                parts: [
                  { text: "Analyze this memory." },
                  { inlineData: { mimeType: file.type, data: base64Data } }
                ]
              }],
              systemInstruction: { parts: [{ text: systemPrompt }] }
            })
          }
        );
        const text = result.candidates?.[0]?.content?.parts?.[0]?.text;
        if (text) setAnalyzedMemory(text.trim());
      } catch (err) {
        setAnalyzedMemory("The memory is a bit blurry... but the warmth remains.");
      } finally {
        setAiLoading(false);
      }
    };
    reader.readAsDataURL(file);
  };

  const askTheWind = async () => {
    setAiLoading(true);
    const systemPrompt = "You are the 'Voice of the Wind' in Allen's digital garden. Provide a short piece of calm, Ghibli-esque wisdom about life and patience. Max 20 words.";
    try {
      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contents: [{ parts: [{ text: "Give me wisdom." }] }], systemInstruction: { parts: [{ text: systemPrompt }] } })
        }
      );
      const text = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (text) setWisdom(text.trim());
    } catch (err) {
      setWisdom("Listen closely... the wind is whispering somewhere else right now.");
    } finally {
      setAiLoading(false);
