    ? "bg-[#1a2533] text-slate-200 transition-colors duration-1000" 
    : "bg-[#F5E9DC] text-slate-800 transition-colors duration-1000";

  return (
    <div className={`min-h-screen font-serif ${themeClasses} overflow-x-hidden relative selection:bg-sage-200/50`}>
      <audio ref={audioRef} className="hidden" />
      
      {/* Ghibli Ambient Elements */}
      <div className="fixed inset-0 pointer-events-none z-0">
        {[...Array(15)].map((_, i) => (
          <div key={i} className={`absolute animate-float ${isNight ? 'bg-amber-200 w-1 h-1 rounded-full blur-[1px]' : 'text-sage-300/30'}`}
            style={{ left: `${Math.random() * 100}%`, top: `${Math.random() * 100}%`, animationDelay: `${Math.random() * 5}s`, animationDuration: `${15 + Math.random() * 20}s` }}>
            {!isNight && <Leaf size={14 + Math.random() * 10} />}
          </div>
        ))}
        {!isNight && (
          <div className="opacity-40">
            <Cloud className="absolute top-20 -left-40 text-white animate-drift" size={180} style={{ animationDuration: '80s' }} />
            <Cloud className="absolute top-80 -left-40 text-white animate-drift" size={120} style={{ animationDuration: '110s', animationDelay: '15s' }} />
          </div>
        )}
      </div>

      {/* Navigation */}
      <nav className={`fixed top-0 w-full z-50 px-6 py-4 flex justify-between items-center transition-all ${isNight ? 'bg-[#1a2533]/80 border-slate-700' : 'bg-[#F5E9DC]/80 border-sage-200'} backdrop-blur-md border-b`}>
        <button onClick={() => setView('home')} className="flex items-center space-x-2 group">
          <div className={`w-10 h-10 rounded-full flex items-center justify-center transition-all ${isNight ? 'bg-amber-900/50 text-amber-200' : 'bg-sage-200 text-sage-700'}`}>
            <Flower size={20} />
          </div>
          <span className="text-xl font-bold tracking-tight">Allen</span>
        </button>

        <div className="hidden md:flex items-center space-x-6">
          {['home', 'garden', 'journey', 'prompts', 'community'].map((v) => (
            <button key={v} onClick={() => setView(v)} className={`capitalize text-sm font-medium transition-all ${view === v ? 'text-sage-600 font-bold scale-105' : 'opacity-60 hover:opacity-100'}`}>
              {v}
            </button>
          ))}
          <div className="h-4 w-[1px] bg-slate-300 mx-2"></div>
          <button onClick={() => setIsNight(!isNight)} className="p-2 rounded-full hover:bg-black/5 transition-colors">
            {isNight ? <Sun size={18} /> : <Moon size={18} />}
          </button>
          <div className="flex items-center space-x-2 bg-black/5 px-3 py-1.5 rounded-full">
             <button onClick={() => setIsMuted(!isMuted)} className="hover:scale-110 transition-transform">
              {isMuted ? <VolumeX size={16} /> : <Volume2 size={16} className="text-sage-600" />}
            </button>
          </div>
        </div>

        <button className="md:hidden" onClick={() => setIsMenuOpen(!isMenuOpen)}>
          {isMenuOpen ? <X /> : <Menu />}
        </button>
      </nav>

      {/* Main Content */}
      <main className="pt-32 pb-24 px-6 max-w-5xl mx-auto relative z-10">
        
        {view === 'home' && (
          <div className="space-y-24 animate-in fade-in duration-700">
            <section className="text-center py-12 relative">
              <h1 className={`text-6xl md:text-8xl font-black mb-8 leading-tight tracking-tighter ${isNight ? 'text-white' : 'text-slate-900'}`}>
                Stories <span className="text-sage-600">Breathe</span> <br /> in Silence.
              </h1>
              <p className="text-xl opacity-70 max-w-2xl mx-auto mb-10 font-sans leading-relaxed">
                Welcome to my digital garden. Use ✨ AI to scan your photos or listen to the wind's secrets.
              </p>
              
              <div className={`inline-flex items-start space-x-4 p-6 rounded-3xl text-left max-w-md mx-auto border transition-all hover:shadow-lg ${isNight ? 'bg-slate-800/40 border-slate-700' : 'bg-white border-sage-100 shadow-sm'}`}>
                <div className="p-3 bg-sage-100 text-sage-600 rounded-2xl">
                  <History size={24} />
                </div>
                <div>
                  <div className="flex items-center space-x-2 mb-1">
                    <span className="text-xs font-bold uppercase tracking-widest text-sage-600">On This Day — {ON_THIS_DAY.date}</span>
                    <span className="text-[10px] bg-sage-50 px-2 py-0.5 rounded-full text-sage-700">{ON_THIS_DAY.year}</span>
                  </div>
                  <p className="text-sm italic opacity-80 leading-relaxed">"{ON_THIS_DAY.event}"</p>
                </div>
              </div>
            </section>
          </div>
        )}

        {view === 'garden' && (
          <div className="text-center animate-in zoom-in-95 duration-700 space-y-16">
            <div>
              <h2 className="text-4xl font-bold mb-4">Memory Garden</h2>
              <p className="opacity-60 mb-12">Visualize your journey through the flowers and ✨ AI scanning.</p>
              
              <div className={`relative h-[300px] w-full rounded-[3rem] overflow-hidden flex items-end justify-center px-12 ${isNight ? 'bg-slate-900/40' : 'bg-white/40 shadow-inner'}`}>
                <div className="flex items-end justify-around w-full relative z-10">
                  {gardenPlants.map((p) => (
                    <div key={p.id} className={`relative flex flex-col items-center group animate-sway transition-transform ${p.size}`} style={{ animationDelay: p.delay }}>
                      <div className="relative">
                        <div className="w-8 h-8 rounded-full blur-[2px]" style={{ backgroundColor: p.color }}></div>
                        <div className="absolute inset-0 flex items-center justify-center"><Flower size={24} style={{ color: p.color }} /></div>
                      </div>
                      <div className={`w-1 h-20 md:h-32 ${isNight ? 'bg-emerald-800' : 'bg-emerald-400'} rounded-full`}></div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* AI Image Memory Scanner */}
            <div className={`p-8 rounded-[3rem] border border-dashed ${isNight ? 'border-slate-700 bg-slate-800/20' : 'border-sage-200 bg-white/40'}`}>
              <div className="flex flex-col items-center space-y-6">
                <div className="flex items-center space-x-4">
                   <div className="p-4 bg-sage-100 text-sage-600 rounded-full"><Camera size={32} /></div>
                   <div className="text-left">
                     <h3 className="text-xl font-bold">✨ Memory Scanner</h3>
                     <p className="text-sm opacity-60">Upload a photo to see the story it hides.</p>
                   </div>
                </div>
                
                <input type="file" id="memory-upload" className="hidden" accept="image/*" onChange={handleImageUpload} />
                <label htmlFor="memory-upload" className="bg-sage-600 hover:bg-sage-700 text-white px-8 py-3 rounded-full font-bold cursor-pointer transition-all shadow-lg flex items-center space-x-2">
                  <Stars size={18} />
                  <span>Choose a Photo</span>
                </label>

                {aiLoading && <div className="flex items-center space-x-2 text-sage-600"><Loader2 className="animate-spin" /><span>Consulting the spirits...</span></div>}
                
                {analyzedMemory && !aiLoading && (
                  <div className="max-w-xl animate-in fade-in slide-in-from-top-4">
                    <p className="text-lg italic font-serif leading-relaxed text-sage-700">"{analyzedMemory}"</p>
                  </div>
                )}
              </div>
            </div>

            <div className="flex flex-col items-center space-y-6">
              <div className="flex space-x-4">
                <button onClick={askTheWind} disabled={aiLoading} className="bg-amber-100 text-amber-700 px-6 py-3 rounded-full font-bold flex items-center space-x-2 hover:bg-amber-200 transition-colors shadow-sm disabled:opacity-50">
                  <Wind size={18} />
                  <span>✨ Ask the Wind for Wisdom</span>
                </button>
                {wisdom && (
                  <button onClick={() => speakWisdom(wisdom)} disabled={aiLoading} className="bg-indigo-100 text-indigo-700 p-3 rounded-full hover:bg-indigo-200 transition-colors disabled:opacity-50">
                    <Volume1 size={24} />
                  </button>
                )}
              </div>
              {wisdom && <p className="text-xl italic text-amber-600 animate-in fade-in max-w-xl mx-auto">"{wisdom}"</p>}
            </div>
          </div>
        )}

