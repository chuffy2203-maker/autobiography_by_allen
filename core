            </div>
            <div className="relative border-l-2 border-sage-200 ml-4 space-y-12 max-w-2xl mx-auto">
              {JOURNEY_PHASES.map((phase, i) => (
                <div key={i} className="relative pl-8">
                  <div className={`absolute -left-[9px] top-1 w-4 h-4 rounded-full border-4 ${isNight ? 'bg-amber-400 border-slate-900' : 'bg-sage-600 border-[#F5E9DC]'}`}></div>
                  <div className={`p-8 rounded-[2rem] border transition-all hover:translate-x-2 hover:shadow-md ${isNight ? 'bg-slate-800/40 border-slate-700' : 'bg-white border-sage-100 shadow-sm'}`}>
                    <div className="flex items-center justify-between mb-2">
                      <span className="text-sage-600 font-bold">{phase.year}</span>
                    </div>
                    <h3 className="text-2xl font-bold mb-3">{phase.title}</h3>
                    <p className="opacity-70 leading-relaxed font-sans">{phase.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {view === 'prompts' && (
          <div className="max-w-2xl mx-auto py-12 text-center animate-in fade-in">
            <div className="inline-block p-4 bg-sage-100 text-sage-600 rounded-3xl mb-8"><PenTool size={32} /></div>
            <h2 className="text-3xl font-bold mb-4">Reflection Prompts</h2>
            <div className={`p-12 rounded-[3rem] border-2 border-dashed ${isNight ? 'border-slate-700 bg-slate-800/20' : 'border-sage-200 bg-white/40'} min-h-[250px] flex items-center justify-center`}>
              <h3 className="text-3xl md:text-4xl font-serif italic leading-snug">
                {aiLoading ? <Zap className="animate-pulse" /> : `"${activePrompt}"`}
              </h3>
            </div>
            <button onClick={generateAIPrompt} disabled={aiLoading} className="mt-12 group flex items-center space-x-3 mx-auto bg-sage-600 hover:bg-sage-700 text-white px-8 py-4 rounded-full font-bold shadow-xl shadow-sage-600/20 transition-all hover:scale-105">
              <RefreshCw size={20} className={aiLoading ? "animate-spin" : "group-hover:rotate-180 transition-transform duration-500"} />
              <span>✨ Generate AI Prompt</span>
            </button>
          </div>
        )}

        {view === 'community' && (
          <div className="max-w-3xl mx-auto animate-in slide-in-from-right-8 duration-500">
            <h2 className="text-4xl font-bold mb-4">Community Guestbook</h2>
            <p className="opacity-60 mb-12">Leave a message for others. Use ✨ AI to categorize your soul's bloom.</p>
            <div className={`mb-12 p-8 rounded-[2.5rem] shadow-xl ${isNight ? 'bg-slate-800' : 'bg-white border border-sage-50'}`}>
              <textarea value={newComment} onChange={(e) => setNewComment(e.target.value)} className="w-full bg-transparent border-none outline-none resize-none min-h-[120px] text-xl font-serif italic" placeholder="Write a small sentence..."></textarea>
              <div className="flex justify-end mt-4">
                <button onClick={handlePost} disabled={aiLoading || !newComment.trim()} className="bg-sage-600 hover:bg-sage-700 text-white px-6 py-3 rounded-full font-bold shadow-lg shadow-sage-600/20 transition-all flex items-center space-x-2">
                  {aiLoading ? <Stars className="animate-spin" /> : <span>Post Thought</span>}
                  <Send size={18} />
                </button>
              </div>
