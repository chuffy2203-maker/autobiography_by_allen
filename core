    const systemPrompt = "Categorize this text into exactly one of these three words: 'Philosophy', 'Memories', or 'Life Advice'. If unsure, pick 'Philosophy'. Output only the word.";
    let category = "Philosophy";
    try {
      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contents: [{ parts: [{ text: newComment }] }], systemInstruction: { parts: [{ text: systemPrompt }] } })
        }
      );
      const text = result.candidates?.[0]?.content?.parts?.[0]?.text?.trim();
      if (["Philosophy", "Memories", "Life Advice"].includes(text)) category = text;
    } catch (err) { console.error(err); }

    setComments([{ name: "Guest", text: newComment, likes: 0, category }, ...comments]);
    setNewComment("");
    setAiLoading(false);
  };

